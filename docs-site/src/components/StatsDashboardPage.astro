---
interface DashboardStrings {
  locale: string;
  eyebrow: string;
  intro: string;
  lastUpdated: string;
  source: string;
  sourceValue: string;
  branch: string;
  loading: string;
  loadingMessage: string;
  errorPrefix: string;
  overviewTitle: string;
  chartsTitle: string;
  chartsDescription: string;
  viewsChart: string;
  clonesChart: string;
  emptyChart: string;
  referrersTitle: string;
  referrersDescription: string;
  pathsTitle: string;
  pathsDescription: string;
  releasesTitle: string;
  releasesDescription: string;
  legendAssets?: string;
  legendContainers?: string;
  issuesTitle: string;
  issuesDescription: string;
  ciTitle: string;
  ciDescription: string;
  devTitle: string;
  devDescription: string;
  codeVelocityTitle: string;
  codeVelocityDescription: string;
  aiTitle: string;
  aiDescription: string;
  emptyTable: string;
  tableRank: string;
  tableName: string;
  tableViews: string;
  tableUniques: string;
  tablePath: string;
  tableDownloads: string;
  tablePublished: string;
  releaseDraft: string;
  releasePre: string;
  footerNote: string;
  cards: {
    views: string;
    clones: string;
    stars: string;
    forks: string;
    subscribers: string;
    releaseDownloads: string;
    latestRelease: string;
    openIssues: string;
    closedIssues: string;
    openPRs: string;
    closedPRs: string;
    ciRuns: string;
    totalCommits: string;
    linesAdded: string;
    linesDeleted: string;
    aiRatio: string;
  };
  subtotals: {
    uniques14d: string;
    dailyBars: string;
    currentSnapshot: string;
    publishedLabel: string;
    releaseCountLabel: string;
    issuesLabel: string;
    awaitingArchive: string;
    weekLabel: string;
    commitsLabel: string;
    additionsLabel: string;
    deletionsLabel: string;
  };
}

interface Props {
  lang: string;
  title: string;
  description: string;
  backHref: string;
  backLabel: string;
  altHref: string;
  altLabel: string;
  strings: DashboardStrings;
}

const {
  lang,
  title,
  description,
  backHref,
  backLabel,
  altHref,
  altLabel,
  strings,
} = Astro.props;

const repoHref = 'https://github.com/trudenboy/sendspin-bt-bridge';
const branchHref = `${repoHref}/tree/traffic-data/traffic`;
const summaryUrl = `${repoHref.replace('https://github.com', 'https://raw.githubusercontent.com')}/traffic-data/traffic/summary.json`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Sendspin BT Bridge</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: dark;
        --bg: #0b1120;
        --panel: rgba(15, 23, 42, 0.86);
        --panel-strong: rgba(15, 23, 42, 0.96);
        --border: rgba(148, 163, 184, 0.22);
        --text: #e5eefb;
        --muted: #93a4bf;
        --accent: #38bdf8;
        --accent-soft: rgba(56, 189, 248, 0.16);
        --success: #34d399;
        --warning: #fbbf24;
        --danger: #fb7185;
        --shadow: 0 18px 50px rgba(2, 6, 23, 0.42);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top, rgba(56, 189, 248, 0.13), transparent 36%),
          linear-gradient(180deg, #020617 0%, var(--bg) 100%);
        min-height: 100vh;
      }

      a {
        color: inherit;
      }

      .page {
        width: min(1180px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.25rem 0 2rem;
      }

      .topbar,
      .hero,
      .panel,
      .metric-card {
        border: 1px solid var(--border);
        border-radius: 22px;
        background: var(--panel);
        box-shadow: var(--shadow);
        backdrop-filter: blur(16px);
      }

      .topbar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.1rem;
        margin-bottom: 1rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.05rem;
      }

      .brand-mark {
        width: 0.8rem;
        height: 0.8rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #38bdf8 0%, #34d399 100%);
        box-shadow: 0 0 0 6px rgba(56, 189, 248, 0.12);
      }

      .tagline {
        margin: 0.45rem 0 0;
        color: var(--muted);
        max-width: 46rem;
      }

      .top-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.65rem;
      }

      .top-links a {
        text-decoration: none;
        padding: 0.65rem 0.85rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        color: var(--muted);
        background: rgba(15, 23, 42, 0.45);
      }

      .top-links a:hover {
        color: var(--text);
        border-color: rgba(56, 189, 248, 0.45);
        background: rgba(56, 189, 248, 0.08);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
        gap: 1rem;
        padding: 1.2rem;
        margin-bottom: 1rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin: 0 0 0.6rem;
        color: #7dd3fc;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        background: var(--success);
        box-shadow: 0 0 12px rgba(52, 211, 153, 0.9);
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        font-size: clamp(2rem, 3vw, 2.8rem);
        line-height: 1.05;
        margin-bottom: 0.75rem;
      }

      .hero-copy p:last-child {
        color: var(--muted);
        line-height: 1.65;
        max-width: 52rem;
      }

      .status-card {
        background: var(--panel-strong);
        border-radius: 18px;
        border: 1px solid var(--border);
        padding: 1rem;
        display: grid;
        gap: 0.85rem;
        align-content: start;
      }

      .status-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
      }

      .status-row span {
        color: var(--muted);
      }

      .status-message {
        margin: 0 0 1rem;
        padding: 0.9rem 1rem;
        border-radius: 16px;
        border: 1px solid var(--border);
        background: rgba(15, 23, 42, 0.62);
        color: var(--muted);
      }

      .status-message.error {
        color: #ffd5db;
        border-color: rgba(251, 113, 133, 0.32);
        background: rgba(127, 29, 29, 0.24);
      }

      .overview-section {
        margin-bottom: 1rem;
      }

      .section-title,
      .section-copy {
        margin-bottom: 0.75rem;
      }

      .section-copy {
        color: var(--muted);
      }

      .overview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 0.6rem;
      }

      .metric-card {
        padding: 0.85rem 1rem;
        border-radius: 10px;
      }

      .metric-card.ind-warn {
        border-left: 3px solid #fbbf24 !important;
      }

      .metric-card.ind-error {
        border-left: 3px solid #f87171 !important;
      }

      .metric-card.ind-ok {
        border-left: 3px solid #34d399 !important;
      }

      .metric-label {
        display: block;
        color: var(--muted);
        font-size: 0.78rem;
        margin-bottom: 0.25rem;
      }

      .metric-value {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1.15;
      }

      .metric-subtitle {
        margin-top: 0.2rem;
        color: var(--muted);
        font-size: 0.78rem;
      }

      .mc-badge {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 600;
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        margin-top: 0.3rem;
      }

      .mc-badge.ok { background: rgba(52,211,153,0.15); color: #34d399; }
      .mc-badge.warn { background: rgba(251,191,36,0.15); color: #fbbf24; }
      .mc-badge.error { background: rgba(248,113,113,0.15); color: #f87171; }

      .panel-grid {
        display: grid;
        gap: 1rem;
      }

      .panel {
        padding: 1rem;
      }

      .chart-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
      }

      .chart-card {
        border-radius: 18px;
        border: 1px solid var(--border);
        background: rgba(15, 23, 42, 0.55);
        padding: 0.95rem;
      }

      .chart-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: baseline;
        margin-bottom: 0.75rem;
      }

      .chart-header span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .chart-area {
        position: relative;
        width: 100%;
        overflow: visible;
      }

      .chart-area svg {
        display: block;
        width: 100%;
        height: auto;
      }

      .chart-area .data-line {
        fill: none;
        stroke-width: 2;
        stroke-linejoin: round;
        stroke-linecap: round;
      }

      .chart-area .dot {
        transition: r 0.15s ease;
        cursor: pointer;
      }

      .chart-area .dot:hover {
        r: 5.5;
      }

      .chart-tooltip {
        position: absolute;
        pointer-events: none;
        padding: 6px 10px;
        border-radius: 8px;
        background: var(--panel-strong);
        border: 1px solid var(--border);
        color: var(--text);
        font-size: 0.82rem;
        line-height: 1.35;
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.15s ease;
        z-index: 10;
        box-shadow: 0 4px 12px rgba(0,0,0,.4);
        transform: translate(-50%, -100%);
        margin-top: -10px;
      }

      .chart-tooltip.visible {
        opacity: 1;
      }

      .chart-tooltip .tt-date {
        color: var(--muted);
        font-size: 0.78rem;
      }

      .chart-tooltip .tt-value {
        font-weight: 700;
        font-size: 0.95rem;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
      }

      th,
      td {
        text-align: left;
        padding: 0.8rem 0.7rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.14);
        vertical-align: top;
      }

      th {
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 600;
      }

      td small {
        display: block;
        color: var(--muted);
        margin-top: 0.18rem;
      }

      .mono {
        font-family:
          ui-monospace, SFMono-Regular, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
          "Courier New", monospace;
        font-size: 0.92em;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 999px;
        padding: 0.22rem 0.55rem;
        font-size: 0.75rem;
        border: 1px solid var(--border);
        color: var(--muted);
        background: rgba(148, 163, 184, 0.08);
      }

      .chip.pre {
        color: #fde68a;
        border-color: rgba(251, 191, 36, 0.24);
        background: rgba(146, 64, 14, 0.18);
      }

      .releases-chart {
        position: relative;
        width: 100%;
        margin-top: 1rem;
        overflow: visible;
      }

      .releases-chart svg {
        display: block;
        width: 100%;
        height: auto;
      }

      .releases-legend {
        display: flex;
        gap: 1.2rem;
        margin-top: 0.7rem;
        font-size: 0.82rem;
        color: var(--muted);
      }

      .legend-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }

      .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 3px;
        display: inline-block;
      }

      .legend-assets {
        background: var(--accent);
      }

      .legend-containers {
        background: var(--success);
      }

      .table-empty {
        color: var(--muted);
        padding: 1rem 0 0;
      }

      .issues-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 0.75rem;
        margin-top: 0.75rem;
      }

      .issue-card {
        background: rgba(15, 23, 42, 0.55);
        border: 1px solid rgba(148, 163, 191, 0.12);
        border-radius: 10px;
        padding: 0.8rem 1rem;
        text-align: center;
      }

      .issue-card .ic-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--fg);
      }

      .issue-card .ic-label {
        font-size: 0.78rem;
        color: var(--muted);
        margin-top: 0.2rem;
      }

      .ci-badge {
        display: inline-block;
        padding: 0.15rem 0.5rem;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
      }

      .ci-badge.success {
        background: rgba(52, 211, 153, 0.15);
        color: #34d399;
      }

      .ci-badge.failure {
        background: rgba(248, 113, 113, 0.15);
        color: #f87171;
      }

      .ci-badge.cancelled {
        background: rgba(148, 163, 191, 0.15);
        color: #93a4bf;
      }

      .ci-rate {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-weight: 600;
        font-size: 0.85rem;
      }

      .ci-rate.high { color: #34d399; }
      .ci-rate.medium { color: #fbbf24; }
      .ci-rate.low { color: #f87171; }

      .ai-ring-wrap {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-top: 0.75rem;
        flex-wrap: wrap;
      }

      .ai-ring-wrap svg {
        flex-shrink: 0;
      }

      .ai-agents-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .ai-agents-list li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.3rem 0;
        font-size: 0.88rem;
      }

      .ai-agent-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .ai-agent-count {
        color: var(--muted);
        font-size: 0.78rem;
        margin-left: auto;
      }

      .footer-note {
        margin-top: 1rem;
        color: var(--muted);
        font-size: 0.9rem;
      }

      @media (max-width: 900px) {
        .hero {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .page {
          width: min(100% - 1rem, 1180px);
        }

        .topbar {
          flex-direction: column;
        }

        .top-links {
          justify-content: flex-start;
        }

        th:nth-child(3),
        td:nth-child(3) {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="topbar">
        <div>
          <a class="brand" href={backHref}>
            <span class="brand-mark"></span>
            <span>Sendspin BT Bridge</span>
          </a>
          <p class="tagline">{description}</p>
        </div>
        <nav class="top-links">
          <a href={backHref}>{backLabel}</a>
          <a href={altHref}>{altLabel}</a>
          <a href={repoHref}>GitHub</a>
          <a href={branchHref}>traffic-data</a>
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="hero-copy">
            <p class="eyebrow">{strings.eyebrow}</p>
            <h1>{title}</h1>
            <p>{strings.intro}</p>
          </div>

          <aside class="status-card">
            <div class="status-row">
              <span>{strings.lastUpdated}</span>
              <strong id="last-updated">{strings.loading}</strong>
            </div>
            <div class="status-row">
              <span>{strings.source}</span>
              <strong>{strings.sourceValue}</strong>
            </div>
            <div class="status-row">
              <span>{strings.branch}</span>
              <strong>traffic-data</strong>
            </div>
          </aside>
        </section>

        <p id="status-message" class="status-message">{strings.loadingMessage}</p>

        <section class="overview-section">
          <h2 class="section-title">{strings.overviewTitle}</h2>
          <div id="overview-cards" class="overview-grid"></div>
        </section>

        <div class="panel-grid">
          <section class="panel">
            <h2 class="section-title">{strings.chartsTitle}</h2>
            <p class="section-copy">{strings.chartsDescription}</p>
            <div class="chart-grid">
              <div class="chart-card">
                <div class="chart-header">
                  <h3>{strings.viewsChart}</h3>
                  <span id="views-chart-total">—</span>
                </div>
                <div id="views-chart" class="chart-area"></div>
              </div>
              <div class="chart-card">
                <div class="chart-header">
                  <h3>{strings.clonesChart}</h3>
                  <span id="clones-chart-total">—</span>
                </div>
                <div id="clones-chart" class="chart-area"></div>
              </div>
            </div>
          </section>

          <section class="panel">
            <h2 class="section-title">{strings.referrersTitle}</h2>
            <p class="section-copy">{strings.referrersDescription}</p>
            <div id="referrers-empty" class="table-empty" hidden>{strings.emptyTable}</div>
            <table id="referrers-table" hidden>
              <thead>
                <tr>
                  <th>{strings.tableRank}</th>
                  <th>{strings.tableName}</th>
                  <th>{strings.tableViews}</th>
                  <th>{strings.tableUniques}</th>
                </tr>
              </thead>
              <tbody id="referrers-body"></tbody>
            </table>
          </section>

          <section class="panel">
            <h2 class="section-title">{strings.pathsTitle}</h2>
            <p class="section-copy">{strings.pathsDescription}</p>
            <div id="paths-empty" class="table-empty" hidden>{strings.emptyTable}</div>
            <table id="paths-table" hidden>
              <thead>
                <tr>
                  <th>{strings.tableRank}</th>
                  <th>{strings.tablePath}</th>
                  <th>{strings.tableViews}</th>
                  <th>{strings.tableUniques}</th>
                </tr>
              </thead>
              <tbody id="paths-body"></tbody>
            </table>
          </section>

          <section class="panel">
            <h2 class="section-title">{strings.releasesTitle}</h2>
            <p class="section-copy">{strings.releasesDescription}</p>
            <div id="releases-empty" class="table-empty" hidden>{strings.emptyTable}</div>
            <div id="releases-chart" class="releases-chart" hidden></div>
            <div id="releases-legend" class="releases-legend" hidden>
              <span class="legend-item"><span class="legend-dot legend-assets"></span> {strings.legendAssets ?? 'Assets'}</span>
              <span class="legend-item"><span class="legend-dot legend-containers"></span> {strings.legendContainers ?? 'Containers'}</span>
            </div>
          </section>

          <section class="panel">
            <h2 class="section-title">{strings.issuesTitle}</h2>
            <p class="section-copy">{strings.issuesDescription}</p>
            <div id="issues-cards" class="issues-grid" hidden></div>
            <div id="issues-empty" class="table-empty" hidden>{strings.emptyTable}</div>
          </section>

          <section class="panel">
            <h2 class="section-title">{strings.ciTitle}</h2>
            <p class="section-copy">{strings.ciDescription}</p>
            <div id="ci-empty" class="table-empty" hidden>{strings.emptyTable}</div>
            <table id="ci-table" class="stat-table" hidden>
              <thead>
                <tr>
                  <th>Workflow</th>
                  <th>Runs</th>
                  <th>Success</th>
                  <th>Fail</th>
                  <th>Rate</th>
                  <th>Last run</th>
                </tr>
              </thead>
              <tbody id="ci-body"></tbody>
            </table>
          </section>

          <section class="panel">
            <h2 class="section-title">{strings.devTitle}</h2>
            <p class="section-copy">{strings.devDescription}</p>
            <div id="commits-chart" class="chart-container" style="min-height:220px"></div>
            <div id="commits-empty" class="table-empty" hidden>{strings.emptyTable}</div>
          </section>

          <section class="panel">
            <h2 class="section-title">{strings.codeVelocityTitle}</h2>
            <p class="section-copy">{strings.codeVelocityDescription}</p>
            <div id="code-freq-chart" class="chart-container" style="min-height:220px"></div>
            <div id="code-freq-empty" class="table-empty" hidden>{strings.emptyTable}</div>
          </section>

          <section class="panel">
            <h2 class="section-title">{strings.aiTitle}</h2>
            <p class="section-copy">{strings.aiDescription}</p>
            <div id="ai-cards" class="issues-grid" hidden></div>
            <div id="ai-empty" class="table-empty" hidden>{strings.emptyTable}</div>
          </section>
        </div>

        <p class="footer-note">{strings.footerNote}</p>
      </main>
    </div>

    <script
      is:inline
      define:vars={{
        strings,
        summaryUrl,
      }}
    >
      const statusMessage = document.getElementById('status-message');
      const lastUpdatedEl = document.getElementById('last-updated');
      const overviewCards = document.getElementById('overview-cards');
      const viewsChart = document.getElementById('views-chart');
      const viewsChartTotal = document.getElementById('views-chart-total');
      const clonesChart = document.getElementById('clones-chart');
      const clonesChartTotal = document.getElementById('clones-chart-total');
      const referrersTable = document.getElementById('referrers-table');
      const referrersBody = document.getElementById('referrers-body');
      const referrersEmpty = document.getElementById('referrers-empty');
      const pathsTable = document.getElementById('paths-table');
      const pathsBody = document.getElementById('paths-body');
      const pathsEmpty = document.getElementById('paths-empty');
      const releasesChart = document.getElementById('releases-chart');
      const releasesLegend = document.getElementById('releases-legend');
      const releasesEmpty = document.getElementById('releases-empty');
      const issuesCards = document.getElementById('issues-cards');
      const issuesEmpty = document.getElementById('issues-empty');
      const ciTable = document.getElementById('ci-table');
      const ciBody = document.getElementById('ci-body');
      const ciEmpty = document.getElementById('ci-empty');
      const commitsChart = document.getElementById('commits-chart');
      const commitsEmpty = document.getElementById('commits-empty');
      const codeFreqChart = document.getElementById('code-freq-chart');
      const codeFreqEmpty = document.getElementById('code-freq-empty');
      const aiCards = document.getElementById('ai-cards');
      const aiEmpty = document.getElementById('ai-empty');

      const numberFormatter = new Intl.NumberFormat(strings.locale);
      const dateTimeFormatter = new Intl.DateTimeFormat(strings.locale, {
        dateStyle: 'medium',
        timeStyle: 'short',
      });
      const dayFormatter = new Intl.DateTimeFormat(strings.locale, {
        month: 'short',
        day: 'numeric',
      });

      function escapeHtml(value) {
        return String(value ?? '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      }

      function formatNumber(value) {
        return numberFormatter.format(Number(value || 0));
      }

      function niceRound(v) {
        if (v <= 0) return 1;
        const mag = Math.pow(10, Math.floor(Math.log10(v)));
        const norm = v / mag;
        const nice = norm <= 1.5 ? 2 : norm <= 3.5 ? 5 : 10;
        return nice * mag;
      }

      function buildTicks(nMax) {
        if (nMax <= 5) return Array.from({ length: nMax + 1 }, (_, i) => i);
        const step = niceRound(nMax / 4);
        const ticks = [];
        for (let t = 0; t <= nMax; t += step) ticks.push(t);
        if (ticks[ticks.length - 1] < nMax) ticks.push(nMax);
        return ticks;
      }

      function abbreviate(n) {
        if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
        if (n >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, '') + 'k';
        return String(n);
      }

      function historyEntries(history) {
        return Object.entries(history || {})
          .map(([timestamp, values]) => ({
            timestamp,
            date: new Date(timestamp),
            count: Number(values?.count || 0),
            uniques: Number(values?.uniques || 0),
          }))
          .sort((a, b) => a.date - b.date);
      }

      function sumCounts(entries) {
        return entries.reduce((sum, entry) => sum + entry.count, 0);
      }

      function metricValue(value, fallback = '—') {
        return value == null ? fallback : formatNumber(value);
      }

      function renderMetricCards(summary) {
        const viewsEntries = historyEntries(summary.views);
        const clonesEntries = historyEntries(summary.clones);
        const viewsCount = summary.views_window?.count ?? sumCounts(viewsEntries);
        const clonesCount = summary.clones_window?.count ?? sumCounts(clonesEntries);

        const openIssuesCount = summary.issues?.open_issues ?? summary.repo?.open_issues_count ?? 0;
        const ciWorkflows = summary.ci || [];
        const ciHasFailure = ciWorkflows.some(w => w.last_status === 'failure');
        const ciNoFailures = ciWorkflows.length > 0 && !ciHasFailure;
        const ciRate = ciWorkflows.length > 0
          ? (ciWorkflows.reduce((s, w) => s + (w.success_runs || 0), 0) /
             Math.max(1, ciWorkflows.reduce((s, w) => s + (w.total_runs || 0), 0)) * 100).toFixed(0)
          : null;

        function tile(label, value, sub, ind, badgeText, badgeType) {
          const cls = ind ? ` ind-${ind}` : '';
          const bg = badgeText ? `<div class="mc-badge ${badgeType}">${escapeHtml(badgeText)}</div>` : '';
          return `<article class="metric-card${cls}">
            <span class="metric-label">${escapeHtml(label)}</span>
            <div class="metric-value">${escapeHtml(value)}</div>
            <p class="metric-subtitle">${escapeHtml(sub)}</p>
            ${bg}
          </article>`;
        }

        const w = strings.subtotals;
        const c = strings.cards;
        const r = summary.releases;
        const iss = summary.issues;
        const dev = summary.dev;

        overviewCards.innerHTML = [
          // Traffic
          tile(c.views, metricValue(viewsCount),
            summary.views_window?.uniques != null ? `${formatNumber(summary.views_window.uniques)} ${w.uniques14d}` : w.awaitingArchive),
          tile(c.clones, metricValue(clonesCount),
            summary.clones_window?.uniques != null ? `${formatNumber(summary.clones_window.uniques)} ${w.uniques14d}` : w.awaitingArchive),
          // Repository
          tile(c.stars, metricValue(summary.repo?.stargazers_count),
            summary.repo ? w.currentSnapshot : w.awaitingArchive),
          tile(c.forks, metricValue(summary.repo?.forks_count),
            summary.repo ? w.currentSnapshot : w.awaitingArchive),
          tile(c.subscribers, metricValue(summary.repo?.subscribers_count),
            summary.repo ? w.currentSnapshot : w.awaitingArchive),
          // Releases
          tile(c.releaseDownloads, metricValue(r?.total_downloads),
            r?.release_count != null ? `${formatNumber(r.release_count)} ${w.releaseCountLabel}` : w.awaitingArchive),
          tile(c.latestRelease, r?.latest_release_tag ?? '—',
            r?.latest_release_published_at ? `${w.publishedLabel} ${dateTimeFormatter.format(new Date(r.latest_release_published_at))}` : w.awaitingArchive),
          // Health — with indicators
          tile(c.openIssues, metricValue(openIssuesCount),
            iss ? `${formatNumber(iss.closed_issues)} closed` : w.issuesLabel,
            openIssuesCount > 0 ? 'warn' : (iss ? 'ok' : null),
            iss ? (openIssuesCount > 0 ? `${openIssuesCount} need attention` : 'All closed') : null,
            openIssuesCount > 0 ? 'warn' : 'ok'),
          tile(c.closedPRs, metricValue(iss?.closed_prs),
            iss ? `${formatNumber(iss.open_prs)} open` : w.awaitingArchive),
          tile(c.ciRuns, metricValue(ciWorkflows.reduce((s, w) => s + (w.total_runs || 0), 0)),
            ciWorkflows.length > 0 ? `${ciWorkflows.length} workflows` : w.awaitingArchive,
            ciHasFailure ? 'error' : (ciNoFailures ? 'ok' : null),
            ciRate != null ? (ciHasFailure ? `${ciRate}% — has failures` : `${ciRate}% success`) : null,
            ciHasFailure ? 'error' : (ciNoFailures ? 'ok' : 'warn')),
          // Development
          tile(c.totalCommits, metricValue(dev?.weekly_commits?.reduce((s, w) => s + w.total, 0)),
            dev ? `${dev.weekly_commits?.length || 0} ${w.weekLabel}` : w.awaitingArchive),
          tile(c.aiRatio, dev?.ai ? `${(dev.ai.ai_ratio * 100).toFixed(0)}%` : '—',
            dev?.ai ? `${formatNumber(dev.ai.ai_commits)} / ${formatNumber(dev.ai.commits_scanned)} ${w.commitsLabel}` : w.awaitingArchive),
        ].join('');
      }

      function renderChart(container, totalEl, entries, total, colorScheme) {
        if (!entries.length) {
          container.innerHTML = `<div class="table-empty">${escapeHtml(strings.emptyChart)}</div>`;
          totalEl.textContent = strings.emptyChart;
          return;
        }

        const data = entries.slice(-14);
        const max = Math.max(...data.map((e) => e.count), 1);
        totalEl.textContent = `${formatNumber(total)} ${strings.subtotals.dailyBars}`;

        const W = 520;
        const H = 210;
        const padL = 44;
        const padR = 36;
        const padT = 12;
        const padB = 38;
        const chartW = W - padL - padR;
        const chartH = H - padT - padB;

        const niceMax = niceRound(max);
        const ticks = buildTicks(niceMax);

        const gradId = `grad-${Math.random().toString(36).slice(2, 8)}`;
        const [c1, c2] = colorScheme;

        const xStep = data.length > 1 ? chartW / (data.length - 1) : 0;
        const points = data.map((e, i) => ({
          x: padL + i * xStep,
          y: padT + chartH - (e.count / niceMax) * chartH,
          entry: e,
        }));

        const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x},${p.y}`).join(' ');
        const areaPath = `${linePath} L${points[points.length - 1].x},${padT + chartH} L${points[0].x},${padT + chartH} Z`;

        const labelColor = '#93a4bf';
        const gridColor = 'rgba(148,163,184,0.22)';

        let gridLines = '';
        for (const t of ticks) {
          const y = padT + chartH - (t / niceMax) * chartH;
          gridLines += `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" stroke="${gridColor}"/>`;
          gridLines += `<text x="${padL - 8}" y="${y + 4}" fill="${labelColor}" font-size="11" font-family="inherit" text-anchor="end">${abbreviate(t)}</text>`;
        }

        const xLabels = selectXLabels(data, points, padL, W - padR);
        let xLabelSvg = '';
        for (const { x, label } of xLabels) {
          xLabelSvg += `<text x="${x}" y="${H - 6}" fill="${labelColor}" font-size="11" font-family="inherit" text-anchor="middle">${escapeHtml(label)}</text>`;
        }

        let dots = '';
        for (let i = 0; i < points.length; i++) {
          const p = points[i];
          dots += `<circle cx="${p.x}" cy="${p.y}" r="3.5" fill="${c2}" stroke="#0b1120" stroke-width="1.5" class="dot" data-idx="${i}"/>`;
        }

        container.innerHTML = `
          <svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid meet" aria-label="${strings.chartsTitle}">
            <defs>
              <linearGradient id="${gradId}" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="${c1}" stop-opacity="0.6"/>
                <stop offset="85%" stop-color="${c1}" stop-opacity="0.08"/>
                <stop offset="100%" stop-color="${c1}" stop-opacity="0"/>
              </linearGradient>
            </defs>
            ${gridLines}
            <path d="${areaPath}" fill="url(#${gradId})"/>
            <path d="${linePath}" class="data-line" stroke="${c2}"/>
            ${dots}
            ${xLabelSvg}
          </svg>
          <div class="chart-tooltip" id="tt-${gradId}"></div>
        `;

        const tooltip = container.querySelector('.chart-tooltip');
        const svg = container.querySelector('svg');
        container.querySelectorAll('.dot').forEach((dot) => {
          dot.addEventListener('mouseenter', (e) => {
            const idx = Number(dot.dataset.idx);
            const d = data[idx];
            tooltip.innerHTML = `<div class="tt-date">${escapeHtml(dayFormatter.format(d.date))}</div><div class="tt-value">${formatNumber(d.count)}</div>`;
            const rect = svg.getBoundingClientRect();
            const cx = Number(dot.getAttribute('cx'));
            const cy = Number(dot.getAttribute('cy'));
            const px = (cx / W) * rect.width;
            const py = (cy / H) * rect.height;
            tooltip.style.left = `${px}px`;
            tooltip.style.top = `${py}px`;
            tooltip.classList.add('visible');
          });
          dot.addEventListener('mouseleave', () => {
            tooltip.classList.remove('visible');
          });
        });
      }

      function niceRound(val) {
        if (val <= 0) return 1;
        const mag = Math.pow(10, Math.floor(Math.log10(val)));
        const norm = val / mag;
        if (norm <= 1) return mag;
        if (norm <= 2) return 2 * mag;
        if (norm <= 5) return 5 * mag;
        return 10 * mag;
      }

      function buildTicks(niceMax) {
        const count = 4;
        const step = niceMax / count;
        const ticks = [];
        for (let i = 0; i <= count; i++) ticks.push(Math.round(i * step));
        return ticks;
      }

      function abbreviate(n) {
        if (n >= 1000) return (n / 1000).toFixed(n % 1000 === 0 ? 0 : 1) + 'k';
        return String(n);
      }

      function selectXLabels(data, points, minX, maxX) {
        if (data.length <= 7) {
          return data.map((e, i) => ({
            x: points[i].x,
            label: dayFormatter.format(e.date),
          }));
        }
        const step = Math.ceil(data.length / 5);
        const labels = [];
        for (let i = 0; i < data.length; i += step) {
          labels.push({ x: points[i].x, label: dayFormatter.format(data[i].date) });
        }
        const last = data.length - 1;
        const lastLabelIdx = (labels.length - 1) * step;
        if (last - lastLabelIdx >= step) {
          labels.push({ x: points[last].x, label: dayFormatter.format(data[last].date) });
        } else if (last !== lastLabelIdx) {
          labels[labels.length - 1] = { x: points[last].x, label: dayFormatter.format(data[last].date) };
        }
        return labels;
      }

      function renderRows({ items, emptyEl, tableEl, bodyEl, renderRow }) {
        if (!items.length) {
          emptyEl.hidden = false;
          tableEl.hidden = true;
          bodyEl.innerHTML = '';
          return;
        }
        emptyEl.hidden = true;
        tableEl.hidden = false;
        bodyEl.innerHTML = items.map(renderRow).join('');
      }

      function renderTables(summary) {
        const referrers = (summary.referrers || []).slice(0, 10);
        renderRows({
          items: referrers,
          emptyEl: referrersEmpty,
          tableEl: referrersTable,
          bodyEl: referrersBody,
          renderRow: (item, index) => `
            <tr>
              <td>${index + 1}</td>
              <td>${escapeHtml(item.referrer)}</td>
              <td>${escapeHtml(formatNumber(item.count))}</td>
              <td>${escapeHtml(formatNumber(item.uniques))}</td>
            </tr>
          `,
        });

        const paths = (summary.paths || []).slice(0, 10);
        renderRows({
          items: paths,
          emptyEl: pathsEmpty,
          tableEl: pathsTable,
          bodyEl: pathsBody,
          renderRow: (item, index) => `
            <tr>
              <td>${index + 1}</td>
              <td class="mono">${escapeHtml(item.path)}<small>${escapeHtml(item.title || '')}</small></td>
              <td>${escapeHtml(formatNumber(item.count))}</td>
              <td>${escapeHtml(formatNumber(item.uniques))}</td>
            </tr>
          `,
        });

        const containerByTag = summary.container?.by_tag || {};
        const releases = Object.entries(summary.releases?.by_tag || {})
          .map(([tag, values]) => ({
            tag,
            ...values,
            container_images: containerByTag[tag] || 0,
          }))
          .filter((r) => !r.prerelease)
          .sort((a, b) => new Date(a.published_at || 0) - new Date(b.published_at || 0))
          .slice(-30);

        renderReleasesChart(releases);
      }

      function renderReleasesChart(releases) {
        if (!releases.length) {
          releasesEmpty.hidden = false;
          releasesChart.hidden = true;
          releasesLegend.hidden = true;
          return;
        }

        releasesEmpty.hidden = true;
        releasesChart.hidden = false;
        releasesLegend.hidden = false;

        const n = releases.length;
        const maxVal = Math.max(
          ...releases.map((r) => (r.asset_downloads || 0) + (r.container_images || 0)),
          1
        );

        const W = 720;
        const padL = 38;
        const padR = 8;
        const padT = 12;
        const padB = 58;
        const barGap = 3;
        const chartW = W - padL - padR;
        const barW = Math.max((chartW - barGap * (n - 1)) / n, 4);
        const barMaxH = 130;
        const H = padT + barMaxH + padB;

        const labelColor = '#93a4bf';
        const gridColor = 'rgba(148,163,184,0.22)';
        const assetColor = '#38bdf8';
        const containerColor = '#34d399';

        const nMax = niceRound(maxVal);
        const ticks = buildTicks(nMax);

        let gridSvg = '';
        for (const t of ticks) {
          const y = padT + barMaxH - (t / nMax) * barMaxH;
          gridSvg += `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" stroke="${gridColor}"/>`;
          gridSvg += `<text x="${padL - 6}" y="${y + 4}" fill="${labelColor}" font-size="10" text-anchor="end">${abbreviate(t)}</text>`;
        }

        let barsSvg = '';
        const hitAreas = [];
        for (let i = 0; i < n; i++) {
          const r = releases[i];
          const assets = r.asset_downloads || 0;
          const containers = r.container_images || 0;
          const total = assets + containers;
          const x = padL + i * (barW + barGap);
          const baseY = padT + barMaxH;

          const assetsH = total > 0 ? Math.max((assets / nMax) * barMaxH, assets > 0 ? 2 : 0) : 0;
          const containersH = total > 0 ? Math.max((containers / nMax) * barMaxH, containers > 0 ? 2 : 0) : 0;
          const totalH = assetsH + containersH;

          if (totalH > 0) {
            barsSvg += `<rect x="${x}" y="${baseY - assetsH}" width="${barW}" height="${assetsH}" rx="1" fill="${assetColor}"/>`;
            barsSvg += `<rect x="${x}" y="${baseY - assetsH - containersH}" width="${barW}" height="${containersH}" rx="1" fill="${containerColor}"/>`;
          } else {
            barsSvg += `<rect x="${x}" y="${baseY - 2}" width="${barW}" height="2" rx="1" fill="${gridColor}"/>`;
          }

          hitAreas.push({ x, r, total, assets, containers });

          const shortTag = r.tag.replace(/^v/, '');
          const showLabel = n <= 20 || i % Math.ceil(n / 20) === 0 || i === n - 1;
          if (showLabel) {
            barsSvg += `<text x="${x + barW / 2}" y="${baseY + 12}" fill="${labelColor}" font-size="8" text-anchor="end" transform="rotate(-55 ${x + barW / 2} ${baseY + 12})">${escapeHtml(shortTag)}</text>`;
          }
        }

        releasesChart.innerHTML = `
          <svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid meet">
            ${gridSvg}
            ${barsSvg}
            ${hitAreas.map((h, i) => `<rect x="${h.x}" y="${padT}" width="${barW}" height="${barMaxH}" fill="transparent" data-idx="${i}" class="rel-hit"/>`).join('')}
          </svg>
          <div class="chart-tooltip" id="rel-tt"></div>
        `;

        const tooltip = releasesChart.querySelector('#rel-tt');
        const svg = releasesChart.querySelector('svg');
        releasesChart.querySelectorAll('.rel-hit').forEach((hit) => {
          hit.style.cursor = 'pointer';
          hit.addEventListener('mouseenter', () => {
            const idx = Number(hit.dataset.idx);
            const h = hitAreas[idx];
            const published = h.r.published_at ? dayFormatter.format(new Date(h.r.published_at)) : '';
            tooltip.innerHTML = [
              `<div style="font-weight:700">${escapeHtml(h.r.tag)}</div>`,
              published ? `<div class="tt-date">${escapeHtml(published)}</div>` : '',
              `<div>Assets: <strong>${formatNumber(h.assets)}</strong></div>`,
              `<div>Container pulls: <strong>${formatNumber(h.containers)}</strong></div>`,
            ].join('');
            const rect = svg.getBoundingClientRect();
            const px = ((h.x + barW / 2) / W) * rect.width;
            tooltip.style.left = `${px}px`;
            tooltip.style.top = `${(padT / H) * rect.height - 4}px`;
            tooltip.classList.add('visible');
          });
          hit.addEventListener('mouseleave', () => {
            tooltip.classList.remove('visible');
          });
        });
      }

      function renderIssues(summary) {
        const issues = summary.issues;
        if (!issues) {
          issuesEmpty.hidden = false;
          issuesCards.hidden = true;
          return;
        }
        issuesEmpty.hidden = true;
        issuesCards.hidden = false;

        const items = [
          { label: strings.cards.openIssues, value: issues.open_issues, color: '#fbbf24' },
          { label: strings.cards.closedIssues, value: issues.closed_issues, color: '#34d399' },
          { label: strings.cards.openPRs, value: issues.open_prs, color: '#38bdf8' },
          { label: strings.cards.closedPRs, value: issues.closed_prs, color: '#a78bfa' },
        ];

        issuesCards.innerHTML = items
          .map(
            (item) => `
              <div class="issue-card">
                <div class="ic-value" style="color:${item.color}">${formatNumber(item.value)}</div>
                <div class="ic-label">${escapeHtml(item.label)}</div>
              </div>
            `
          )
          .join('');
      }

      function renderCI(summary) {
        const workflows = summary.ci;
        if (!workflows || !workflows.length) {
          ciEmpty.hidden = false;
          ciTable.hidden = true;
          return;
        }
        ciEmpty.hidden = true;
        ciTable.hidden = false;

        ciBody.innerHTML = workflows
          .sort((a, b) => (b.total_runs || 0) - (a.total_runs || 0))
          .map((wf) => {
            const rate = wf.total_runs > 0
              ? ((wf.success_runs / wf.total_runs) * 100).toFixed(1)
              : '—';
            const rateClass = rate === '—' ? '' : (rate >= 90 ? 'high' : rate >= 70 ? 'medium' : 'low');
            const statusClass = wf.last_status === 'success'
              ? 'success'
              : wf.last_status === 'failure'
                ? 'failure'
                : 'cancelled';
            const lastRun = wf.last_run_at
              ? dayFormatter.format(new Date(wf.last_run_at))
              : '—';
            return `
              <tr>
                <td><strong>${escapeHtml(wf.name)}</strong></td>
                <td>${formatNumber(wf.total_runs)}</td>
                <td>${formatNumber(wf.success_runs)}</td>
                <td>${formatNumber(wf.failure_runs)}</td>
                <td><span class="ci-rate ${rateClass}">${rate}%</span></td>
                <td>
                  <span class="ci-badge ${statusClass}">${escapeHtml(wf.last_status || '—')}</span>
                  <small style="color:var(--muted);margin-left:0.3rem">${escapeHtml(lastRun)}</small>
                </td>
              </tr>
            `;
          })
          .join('');
      }

      function renderCommitsChart(dev) {
        const weeks = dev?.weekly_commits;
        if (!weeks || !weeks.length) {
          commitsEmpty.hidden = false;
          commitsChart.innerHTML = '';
          return;
        }
        commitsEmpty.hidden = true;

        const W = 700, H = 200;
        const padL = 50, padR = 15, padT = 20, padB = 40;
        const cW = W - padL - padR, cH = H - padT - padB;

        const maxVal = Math.max(...weeks.map(w => w.total), 1);
        const barW = Math.max(2, cW / weeks.length - 2);

        const weekFmt = (offset) => {
          const d = new Date();
          d.setDate(d.getDate() + offset * 7);
          return dayFormatter.format(d);
        };

        // Y-axis grid
        const ySteps = 4;
        let gridLines = '';
        let yLabels = '';
        for (let i = 0; i <= ySteps; i++) {
          const val = Math.round((maxVal / ySteps) * i);
          const y = padT + cH - (val / maxVal) * cH;
          gridLines += `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" stroke="#93a4bf" stroke-opacity="0.15"/>`;
          yLabels += `<text x="${padL - 6}" y="${y + 4}" text-anchor="end" fill="#93a4bf" font-size="11">${val}</text>`;
        }

        // Bars
        let bars = '';
        let hits = '';
        const step = Math.ceil(weeks.length / 6);
        let xLabels = '';
        weeks.forEach((w, i) => {
          const x = padL + (i / weeks.length) * cW + 1;
          const ownerH = (w.owner / maxVal) * cH;
          const othersH = ((w.total - w.owner) / maxVal) * cH;
          const baseY = padT + cH;

          bars += `<rect x="${x}" y="${baseY - ownerH}" width="${barW}" height="${ownerH}" fill="#a78bfa" rx="1"/>`;
          if (othersH > 0) {
            bars += `<rect x="${x}" y="${baseY - ownerH - othersH}" width="${barW}" height="${othersH}" fill="#38bdf8" rx="1"/>`;
          }

          // Hit area for tooltip
          hits += `
            <rect class="bar-hit" data-idx="${i}" x="${x}" y="${padT}" width="${barW}" height="${cH}" fill="transparent" style="cursor:crosshair"/>
          `;

          if (i % step === 0 || i === weeks.length - 1) {
            xLabels += `<text x="${x + barW / 2}" y="${H - 5}" text-anchor="middle" fill="#93a4bf" font-size="10">${weekFmt(w.week_offset)}</text>`;
          }
        });

        commitsChart.innerHTML = `
          <div style="position:relative">
            <svg viewBox="0 0 ${W} ${H}" width="100%" preserveAspectRatio="xMidYMid meet">
              ${gridLines}${yLabels}${bars}${xLabels}${hits}
            </svg>
            <div class="chart-tooltip" style="position:absolute;display:none;background:rgba(15,23,42,0.95);border:1px solid rgba(148,163,191,0.25);border-radius:8px;padding:0.4rem 0.6rem;font-size:0.8rem;pointer-events:none;z-index:10;color:#e2e8f0">
            </div>
          </div>
          <div style="display:flex;gap:1rem;margin-top:0.5rem;font-size:0.78rem;color:#93a4bf">
            <span><span style="display:inline-block;width:10px;height:10px;background:#a78bfa;border-radius:2px;margin-right:4px"></span>Owner</span>
            <span><span style="display:inline-block;width:10px;height:10px;background:#38bdf8;border-radius:2px;margin-right:4px"></span>Others</span>
          </div>
        `;

        const svg = commitsChart.querySelector('svg');
        const tooltip = commitsChart.querySelector('.chart-tooltip');
        const rect = svg.getBoundingClientRect();
        svg.querySelectorAll('.bar-hit').forEach((hit) => {
          hit.addEventListener('mouseenter', (e) => {
            const idx = +hit.dataset.idx;
            const w = weeks[idx];
            tooltip.innerHTML = `<div style="font-weight:600">${weekFmt(w.week_offset)}</div><div>${w.total} ${strings.subtotals.commitsLabel} (${w.owner} owner)</div>`;
            tooltip.style.display = 'block';
            const bx = hit.getBoundingClientRect();
            tooltip.style.left = `${bx.left - rect.left + barW / 2}px`;
            tooltip.style.top = `${padT - 4}px`;
          });
          hit.addEventListener('mouseleave', () => {
            tooltip.style.display = 'none';
          });
        });
      }

      function renderCodeFreqChart(dev) {
        const freq = dev?.code_frequency;
        if (!freq || !freq.length) {
          codeFreqEmpty.hidden = false;
          codeFreqChart.innerHTML = '';
          return;
        }
        codeFreqEmpty.hidden = true;

        const W = 700, H = 200;
        const padL = 55, padR = 15, padT = 20, padB = 40;
        const cW = W - padL - padR, cH = H - padT - padB;

        const maxAdd = Math.max(...freq.map(w => w.additions), 1);
        const maxDel = Math.max(...freq.map(w => w.deletions), 1);
        const maxVal = Math.max(maxAdd, maxDel);

        const barW = Math.max(2, (cW / freq.length - 4) / 2);
        const step = Math.ceil(freq.length / 6);

        let gridLines = '';
        let yLabels = '';
        const ySteps = 4;
        for (let i = 0; i <= ySteps; i++) {
          const val = Math.round((maxVal / ySteps) * i);
          const y = padT + cH - (val / maxVal) * cH;
          gridLines += `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" stroke="#93a4bf" stroke-opacity="0.15"/>`;
          yLabels += `<text x="${padL - 6}" y="${y + 4}" text-anchor="end" fill="#93a4bf" font-size="11">${val >= 1000 ? (val / 1000).toFixed(0) + 'k' : val}</text>`;
        }

        let bars = '';
        let xLabels = '';
        let hits = '';
        freq.forEach((w, i) => {
          const groupX = padL + (i / freq.length) * cW + 1;
          const addH = (w.additions / maxVal) * cH;
          const delH = (w.deletions / maxVal) * cH;
          const baseY = padT + cH;

          bars += `<rect x="${groupX}" y="${baseY - addH}" width="${barW}" height="${addH}" fill="#34d399" rx="1"/>`;
          bars += `<rect x="${groupX + barW + 1}" y="${baseY - delH}" width="${barW}" height="${delH}" fill="#f87171" rx="1"/>`;

          hits += `<rect class="bar-hit" data-idx="${i}" x="${groupX}" y="${padT}" width="${barW * 2 + 1}" height="${cH}" fill="transparent" style="cursor:crosshair"/>`;

          if (i % step === 0 || i === freq.length - 1) {
            xLabels += `<text x="${groupX + barW}" y="${H - 5}" text-anchor="middle" fill="#93a4bf" font-size="10">${w.week}</text>`;
          }
        });

        codeFreqChart.innerHTML = `
          <div style="position:relative">
            <svg viewBox="0 0 ${W} ${H}" width="100%" preserveAspectRatio="xMidYMid meet">
              ${gridLines}${yLabels}${bars}${xLabels}${hits}
            </svg>
            <div class="chart-tooltip" style="position:absolute;display:none;background:rgba(15,23,42,0.95);border:1px solid rgba(148,163,191,0.25);border-radius:8px;padding:0.4rem 0.6rem;font-size:0.8rem;pointer-events:none;z-index:10;color:#e2e8f0">
            </div>
          </div>
          <div style="display:flex;gap:1rem;margin-top:0.5rem;font-size:0.78rem;color:#93a4bf">
            <span><span style="display:inline-block;width:10px;height:10px;background:#34d399;border-radius:2px;margin-right:4px"></span>${strings.subtotals.additionsLabel}</span>
            <span><span style="display:inline-block;width:10px;height:10px;background:#f87171;border-radius:2px;margin-right:4px"></span>${strings.subtotals.deletionsLabel}</span>
          </div>
        `;

        const svg = codeFreqChart.querySelector('svg');
        const tooltip = codeFreqChart.querySelector('.chart-tooltip');
        const rect = svg.getBoundingClientRect();
        svg.querySelectorAll('.bar-hit').forEach((hit) => {
          hit.addEventListener('mouseenter', () => {
            const idx = +hit.dataset.idx;
            const w = freq[idx];
            tooltip.innerHTML = `<div style="font-weight:600">${w.week}</div><div style="color:#34d399">+${formatNumber(w.additions)}</div><div style="color:#f87171">−${formatNumber(w.deletions)}</div>`;
            tooltip.style.display = 'block';
            const bx = hit.getBoundingClientRect();
            tooltip.style.left = `${bx.left - rect.left + barW}px`;
            tooltip.style.top = `${padT - 4}px`;
          });
          hit.addEventListener('mouseleave', () => {
            tooltip.style.display = 'none';
          });
        });
      }

      function renderAI(dev) {
        const ai = dev?.ai;
        if (!ai || ai.commits_scanned === 0) {
          aiEmpty.hidden = false;
          aiCards.hidden = true;
          return;
        }
        aiEmpty.hidden = true;
        aiCards.hidden = false;

        const pct = (ai.ai_ratio * 100).toFixed(1);
        const agents = ai.agents || [];

        // Donut ring SVG
        const R = 50, stroke = 12, cx = 60, cy = 60;
        const circ = 2 * Math.PI * R;
        const filled = circ * ai.ai_ratio;
        const agentColors = ['#a78bfa', '#38bdf8', '#fbbf24', '#f87171', '#34d399'];

        const ring = `
          <svg width="120" height="120" viewBox="0 0 120 120">
            <circle cx="${cx}" cy="${cy}" r="${R}" fill="none" stroke="rgba(148,163,191,0.15)" stroke-width="${stroke}"/>
            <circle cx="${cx}" cy="${cy}" r="${R}" fill="none" stroke="#a78bfa" stroke-width="${stroke}"
              stroke-dasharray="${filled} ${circ - filled}" stroke-dashoffset="${circ / 4}"
              stroke-linecap="round" transform="rotate(-90 ${cx} ${cy})"/>
            <text x="${cx}" y="${cy - 4}" text-anchor="middle" fill="#e2e8f0" font-size="18" font-weight="700">${pct}%</text>
            <text x="${cx}" y="${cy + 14}" text-anchor="middle" fill="#93a4bf" font-size="10">AI</text>
          </svg>
        `;

        const agentList = agents.length > 0
          ? `<ul class="ai-agents-list">${agents.map((a, i) => `
              <li>
                <span class="ai-agent-dot" style="background:${agentColors[i % agentColors.length]}"></span>
                <span>${escapeHtml(a.name)}</span>
                <span class="ai-agent-count">${formatNumber(a.commits)} ${strings.subtotals.commitsLabel}</span>
              </li>
            `).join('')}</ul>`
          : '';

        const summaryCards = `
          <div class="issues-grid" style="margin-top:0.75rem">
            <div class="issue-card">
              <div class="ic-value" style="color:#a78bfa">${formatNumber(ai.ai_commits)}</div>
              <div class="ic-label">AI ${strings.subtotals.commitsLabel}</div>
            </div>
            <div class="issue-card">
              <div class="ic-value" style="color:#38bdf8">${formatNumber(ai.commits_scanned - ai.ai_commits)}</div>
              <div class="ic-label">Manual ${strings.subtotals.commitsLabel}</div>
            </div>
            <div class="issue-card">
              <div class="ic-value" style="color:#34d399">${agents.length}</div>
              <div class="ic-label">AI agents</div>
            </div>
          </div>
        `;

        aiCards.innerHTML = `
          <div style="width:100%">
            <div class="ai-ring-wrap">${ring}${agentList}</div>
            ${summaryCards}
          </div>
        `;
      }

      function render(summary) {
        const lastUpdated = summary.last_updated ? new Date(summary.last_updated) : null;
        lastUpdatedEl.textContent = lastUpdated ? dateTimeFormatter.format(lastUpdated) : '—';
        statusMessage.textContent = summary.last_updated
          ? `${strings.sourceValue} · ${dateTimeFormatter.format(new Date(summary.last_updated))}`
          : strings.sourceValue;
        statusMessage.classList.remove('error');

        renderMetricCards(summary);
        const viewsEntries = historyEntries(summary.views);
        const clonesEntries = historyEntries(summary.clones);
        renderChart(viewsChart, viewsChartTotal, viewsEntries, summary.views_window?.count ?? sumCounts(viewsEntries), ['#38bdf8', '#38bdf8']);
        renderChart(clonesChart, clonesChartTotal, clonesEntries, summary.clones_window?.count ?? sumCounts(clonesEntries), ['#34d399', '#34d399']);
        renderTables(summary);
        renderIssues(summary);
        renderCI(summary);
        renderCommitsChart(summary.dev);
        renderCodeFreqChart(summary.dev);
        renderAI(summary.dev);
      }

      async function loadSummary() {
        try {
          const response = await fetch(`${summaryUrl}?ts=${Date.now()}`, {
            cache: 'no-store',
          });
          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }
          const summary = await response.json();
          render(summary);
        } catch (error) {
          statusMessage.textContent = `${strings.errorPrefix} ${error instanceof Error ? error.message : String(error)}`;
          statusMessage.classList.add('error');
          lastUpdatedEl.textContent = '—';
        }
      }

      loadSummary();
    </script>
  </body>
</html>
