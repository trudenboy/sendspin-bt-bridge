# Large dirs not needed in Docker build context
docs-site/
docs/
.git/
deployment/
ha-addon/
ha-addon-beta/
ha-addon-rc/
ha-addon-assets/
.github/
.scratch/
patches/
.playwright-mcp/
.wrangler/
.understand-anything/

# Dev UI source / scratch / sibling CLI — none are runtime deps
ui/
sendspin-cli/
rnd/

# Python bytecode / build artefacts leaking from local runs
**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Tests
tests/
pytest.ini
dev-requirements.txt

# Documentation
*.md
CHANGELOG*
LICENSE

